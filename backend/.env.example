# ============================================
# Monitor-Flow - Environment Configuration
# ============================================

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=seu_usuario
DB_PASS=sua_senha
DB_NAME=monitorflow

# Prisma Database URL
DATABASE_URL=postgresql://seu_usuario:sua_senha@localhost:5432/monitorflow

# JWT
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=24h

# Email (Nodemailer)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=seu_email@gmail.com
MAIL_PASS=sua_senha_de_app
MAIL_FROM="Monitor-Flow <noreply@monitorflow.com>"

# Frontend URL
FRONTEND_URL=http://localhost:9000

# Monitoring Interval (ms)
MONITOR_INTERVAL=60000
